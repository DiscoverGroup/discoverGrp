# CRITICAL SECURITY: JWT Secret (Required - minimum 32 characters)
# Generate a secure secret with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_jwt_secret_here_minimum_32_characters_use_crypto_randomBytes

# MongoDB Connection (Required)
MONGBOD_URI=mongodb://localhost:27017/discovergroup
# For MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/discovergroup

# Stripe Configuration
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here

# Server Configuration
PORT=4000
NODE_ENV=development

# Frontend URLs (for CORS and email links)
FRONTEND_URL=http://localhost:5173
CLIENT_URL=http://localhost:5173
ADMIN_URL=http://localhost:5174

# Email Configuration — Gmail SMTP (required for real email delivery)
GMAIL_USER=your-gmail@gmail.com
GMAIL_APP_PASSWORD=your-16-char-app-password

# How to get an App Password:
# 1. Enable 2-Step Verification on your Google account
# 2. Go to myaccount.google.com/apppasswords
# 3. Create a new App Password (name it e.g. "DiscoverGroup Railway")
# 4. Copy the 16-character password (without spaces) here
# - Mailgun: Use API key

# Cloudinary (image & document storage)
# Get these from https://console.cloudinary.com -> Settings -> API Keys
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Secret Scanner Integration (optional, for Admin Security -> Secret Incidents)
# Example provider: GitGuardian
SECRET_SCANNER_PROVIDER=gitguardian
SECRET_SCANNER_API_URL=https://api.gitguardian.com/v1/incidents/secrets
SECRET_SCANNER_API_TOKEN=your_secret_scanner_api_token
SECRET_SCANNER_AUTH_SCHEME=Token
SECRET_SCANNER_PER_PAGE=50
SECRET_SCANNER_TIMEOUT_MS=10000

# Visa Readiness Score feature flag
VISA_READINESS_ENABLED=true

# ─── Phase 2 Security Enhancements ────────────────────────────────────────────

# Redis (for distributed rate limiting & penalty box — optional, falls back to in-memory)
# Production: set to your Redis instance URL (Redis Cloud, Upstash, Railway Redis, etc.)
# REDIS_URL=redis://localhost:6379

# JWT Claims hardening (recommended for production)
JWT_ISSUER=discovergrp-api
JWT_AUDIENCE=discovergrp-client

# 2FA / TOTP (Two-Factor Authentication for admin accounts)
# Generate a 32-byte hex key: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOTP_ENCRYPTION_KEY=your_totp_encryption_key_min_32_chars_generate_with_crypto_randomBytes
TOTP_APP_NAME=DiscoverGroup

# WAF & Security Alert Notifications (all optional — alerts still logged via Winston)
# Slack: create an incoming webhook at https://api.slack.com/messaging/webhooks
# WAF_SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T.../B.../...
# WAF_ALERT_EMAIL=security@yourdomain.com
# WAF_ALERT_COOLDOWN_MS=60000

# IP Reputation — AbuseIPDB (free tier: 1,000 checks/day)
# Register at https://www.abuseipdb.com/ and generate an API key
# ABUSEIPDB_API_KEY=your_abuseipdb_api_key